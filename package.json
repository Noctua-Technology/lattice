{
  "name": "@noctuatech/lattice",
  "version": "1.0.0",
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "main": "target/lib.js",
  "imports": {
    "#*": {
      "default": "./target/*"
    }
  },
  "exports": {
    ".": "./target/lib.js"
  },
  "files": [
    "src",
    "target"
  ],
  "scripts": {
    "build": "wireit",
    "test": "wireit"
  },
  "wireit": {
    "build": {
      "command": "tsc --build --pretty",
      "clean": "if-file-deleted",
      "files": [
        "src/**",
        "tsconfig.json"
      ],
      "output": [
        "target/**",
        "tsconfig.tsbuildinfo"
      ]
    },
    "test": {
      "command": "node --enable-source-maps --test \"./target/**/*.test.js\"",
      "dependencies": [
        "build"
      ]
    }
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@noctuatech/result": "^1.1.0",
    "hono": "^4.6.16",
    "tslib": "^2.8.1",
    "zod": "^4.1.5"
  },
  "peerDependencies": {
    "@joist/di": "^4.10.2"
  },
  "devDependencies": {
    "@joist/di": "^4.10.2",
    "@types/chai": "^5.2.2",
    "@types/node": "^24.2.1",
    "chai": "^6.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "typescript": "^7.0.1-rc",
    "wireit": "^0.14.12"
  }
}
